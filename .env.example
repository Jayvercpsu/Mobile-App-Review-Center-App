# Flutter API connection settings
# Copy this file to .env (gitignored) and set values for your machine/network.

# Dev API host (Docker): http://api.boardmasters.local:8080/api
# Prod API host: https://api.boardmasters.com/api
API_BASE_URL=http://api.boardmasters.local:8080/api

# Optional public website host used for legal links in-app (Terms/Privacy)
# Dev website host: http://boardmasters.local:8080
# Prod website host: https://boardmasters.com
WEBSITE_BASE_URL=http://boardmasters.local:8080

# Optional extra base URLs (comma/newline/semicolon separated)
API_FALLBACK_BASE_URLS=http://api.boardmasters.local:8080/api,https://api.boardmasters.com/api

# Google Sign-In (Web OAuth client ID from Firebase/Google Cloud)
GOOGLE_SERVER_CLIENT_ID=
