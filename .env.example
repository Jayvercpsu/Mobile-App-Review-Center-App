# Flutter API connection settings
# Copy this file to .env (gitignored) and set values for your machine/network.

# For physical mobile device: use your computer IPv4 (same Wi-Fi), ex: http://192.168.1.10:8000/api
# For Android emulator: use http://10.0.2.2:8000/api
# For Flutter web on same machine: use http://127.0.0.1:8000/api
API_BASE_URL=http://10.0.2.2:8000/api

# Optional extra base URLs (comma/newline/semicolon separated)
API_FALLBACK_BASE_URLS=http://127.0.0.1:8000/api,http://localhost:8000/api

# Google Sign-In (Web OAuth client ID from Firebase/Google Cloud)
GOOGLE_SERVER_CLIENT_ID=166616643070-cu88d2jpq3mhk4t0nn8p93cv9mgvg4q7.apps.googleusercontent.com
